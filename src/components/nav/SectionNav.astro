---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}`, label: "Overview" },
  { href: `${base}trends/`, label: "Tendances" },
  { href: `${base}patterns/`, label: "Patterns" },
  { href: `${base}sound/`, label: "Son" },
  { href: `${base}records/`, label: "Records" },
];
const currentPath = Astro.url.pathname;
---

<nav class="section-nav">
  <a class="brand" href={base}>SPOTlightIFY</a>
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href} aria-current={currentPath === link.href ? "page" : undefined}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .section-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    text-decoration: none;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }

  .section-nav ul {
    list-style: none;
    display: flex;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .section-nav a {
    text-decoration: none;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .section-nav a[aria-current="page"] {
    color: var(--color-text);
  }
</style>
