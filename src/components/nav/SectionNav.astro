---
// Fullscreen PS3/XMB-style navigation screen.
//
// Faithful XMB UX mechanics:
//  - The focused icon does NOT move to the row: the whole row slides so the
//    focused icon always sits at a fixed anchor point (~30% from the left),
//    exactly like the PS3 crossbar.
//  - Arrow keys ←/→ change category, ↑/↓ move through the vertical sub-list,
//    Enter opens — mouse hover does the same thing for pointer users.
//  - Clock top-right, like the XMB.
//  - The vertical sub-list hangs under the focused icon; the selected item is
//    enlarged with its description, siblings are dimmed (cf. the collectui
//    reference: Product → Dashboard/Editor/API/Integrations).
//
// The screen fills 100dvh; page content lives below (scroll cue at the bottom).
const base = import.meta.env.BASE_URL;

const ICONS: Record<string, string> = {
  // Main category icons (drawn for 24x24, stroke 1.8, rounded)
  overview: `<rect x="3" y="3" width="8" height="10" rx="2.5" fill="currentColor" stroke="none"/><rect x="14" y="3" width="7" height="6" rx="2.2" fill="none"/><rect x="14" y="11.5" width="7" height="9.5" rx="2.5" fill="none"/><rect x="3" y="15.5" width="8" height="5.5" rx="2.2" fill="none"/>`,
  trends: `<path d="M3.5 17.5 L9 11.5 L13 15 L20.5 6.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M15.5 6.5 H20.5 V11.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="11.5" r="1.6" fill="currentColor" stroke="none"/><circle cx="13" cy="15" r="1.6" fill="currentColor" stroke="none"/>`,
  patterns: `<circle cx="5.5" cy="5.5" r="2" fill="currentColor" stroke="none"/><circle cx="12" cy="5.5" r="2" fill="currentColor" stroke="none"/><circle cx="18.5" cy="5.5" r="2" fill="none"/><circle cx="5.5" cy="12" r="2" fill="currentColor" stroke="none"/><circle cx="12" cy="12" r="2" fill="none"/><circle cx="18.5" cy="12" r="2" fill="currentColor" stroke="none"/><circle cx="5.5" cy="18.5" r="2" fill="none"/><circle cx="12" cy="18.5" r="2" fill="currentColor" stroke="none"/><circle cx="18.5" cy="18.5" r="2" fill="currentColor" stroke="none"/>`,
  sound: `<rect x="3" y="9" width="2.8" height="6" rx="1.4" fill="currentColor" stroke="none"/><rect x="7.8" y="5.5" width="2.8" height="13" rx="1.4" fill="currentColor" stroke="none"/><rect x="12.6" y="2.5" width="2.8" height="19" rx="1.4" fill="currentColor" stroke="none"/><rect x="17.4" y="7" width="2.8" height="10" rx="1.4" fill="currentColor" stroke="none"/>`,
  records: `<path d="M7.5 3.5h9v5.2a4.5 4.5 0 0 1-9 0V3.5z" fill="currentColor" stroke="none"/><path d="M7.5 4.8H4.6a2.6 2.6 0 0 0 2.6 3.6" fill="none" stroke-linecap="round"/><path d="M16.5 4.8h2.9a2.6 2.6 0 0 1-2.6 3.6" fill="none" stroke-linecap="round"/><path d="M12 13.2v3.4" fill="none" stroke-linecap="round"/><path d="M8.8 20.5c0-1.6 1.4-2.6 3.2-2.6s3.2 1 3.2 2.6" fill="none" stroke-linecap="round"/>`,

  // Small sub-item icons
  clock: `<circle cx="12" cy="12" r="8.5" fill="none"/><path d="M12 7.5V12l3 2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
  artist: `<circle cx="12" cy="8.5" r="3.8" fill="none"/><path d="M4.8 20c.9-3.6 3.8-5.6 7.2-5.6s6.3 2 7.2 5.6" fill="none" stroke-linecap="round"/>`,
  note: `<path d="M9.5 18.2V5.8l9-2v12.4" fill="none" stroke-linejoin="round"/><circle cx="6.7" cy="18.2" r="2.8" fill="currentColor" stroke="none"/><circle cx="15.7" cy="16.2" r="2.8" fill="currentColor" stroke="none"/>`,
  disc: `<circle cx="12" cy="12" r="8.5" fill="none"/><circle cx="12" cy="12" r="2.2" fill="currentColor" stroke="none"/>`,
  spark: `<path d="M12 3l1.8 5.4L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.6L12 3z" fill="currentColor" stroke="none"/><circle cx="18.5" cy="17.5" r="1.8" fill="currentColor" stroke="none"/>`,
  calendar: `<rect x="3.5" y="5" width="17" height="15.5" rx="2.5" fill="none"/><path d="M3.5 9.5h17" fill="none"/><path d="M8 3v3.5M16 3v3.5" fill="none" stroke-linecap="round"/>`,
  heatgrid: `<rect x="4" y="4" width="4.6" height="4.6" rx="1.2" fill="currentColor" stroke="none"/><rect x="9.7" y="4" width="4.6" height="4.6" rx="1.2" fill="none"/><rect x="15.4" y="4" width="4.6" height="4.6" rx="1.2" fill="currentColor" stroke="none"/><rect x="4" y="9.7" width="4.6" height="4.6" rx="1.2" fill="none"/><rect x="9.7" y="9.7" width="4.6" height="4.6" rx="1.2" fill="currentColor" stroke="none"/><rect x="15.4" y="9.7" width="4.6" height="4.6" rx="1.2" fill="none"/><rect x="4" y="15.4" width="4.6" height="4.6" rx="1.2" fill="currentColor" stroke="none"/><rect x="9.7" y="15.4" width="4.6" height="4.6" rx="1.2" fill="none"/><rect x="15.4" y="15.4" width="4.6" height="4.6" rx="1.2" fill="currentColor" stroke="none"/>`,
  smile: `<circle cx="12" cy="12" r="8.5" fill="none"/><path d="M8.2 14.2c.9 1.6 2.2 2.4 3.8 2.4s2.9-.8 3.8-2.4" fill="none" stroke-linecap="round"/><circle cx="9" cy="9.5" r="1.3" fill="currentColor" stroke="none"/><circle cx="15" cy="9.5" r="1.3" fill="currentColor" stroke="none"/>`,
  flame: `<path d="M12 3c.5 3-1.4 4.6-2.8 6.2C7.8 10.8 7 12.3 7 14a5 5 0 0 0 10 0c0-1.5-.6-2.8-1.5-4-.4 1-.9 1.6-1.8 2.1.5-2.9-.3-6.4-1.7-9.1z" fill="currentColor" stroke="none"/>`,
  repeat: `<path d="M4.5 9.5a5 5 0 0 1 5-4.5h7" fill="none" stroke-linecap="round"/><path d="M14 2.5l3 2.5-3 2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M19.5 14.5a5 5 0 0 1-5 4.5h-7" fill="none" stroke-linecap="round"/><path d="M10 21.5L7 19l3-2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
  trendSmall: `<path d="M3.5 17.5 L9 11.5 L13 15 L20.5 6.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
};

interface SubItem {
  icon: string;
  name: string;
  desc: string;
}

interface NavLink {
  href: string;
  label: string;
  icon: string;
  desc: string;
  items: SubItem[];
}

const links: NavLink[] = [
  {
    href: `${base}`,
    label: "Overview",
    icon: "overview",
    desc: "Vue d'ensemble de ton écoute",
    items: [
      { icon: "clock", name: "Temps d'écoute", desc: "Ton total, minute par minute" },
      { icon: "artist", name: "Top artistes", desc: "Les artistes que tu écoutes le plus" },
      { icon: "note", name: "Top titres & albums", desc: "Tes morceaux en boucle" },
      { icon: "spark", name: "Aperçu longue durée", desc: "6 mois et plus, selon Spotify" },
    ],
  },
  {
    href: `${base}trends/`,
    label: "Tendances",
    icon: "trends",
    desc: "Évolution de tes écoutes dans le temps",
    items: [
      { icon: "trendSmall", name: "Minutes par jour", desc: "Moyenne mobile sur 28 jours" },
      { icon: "calendar", name: "Minutes par mois", desc: "La tendance de fond" },
    ],
  },
  {
    href: `${base}patterns/`,
    label: "Patterns",
    icon: "patterns",
    desc: "Tes habitudes d'écoute au fil de la semaine",
    items: [
      { icon: "calendar", name: "Activité quotidienne", desc: "Un an d'écoute, jour par jour" },
      { icon: "heatgrid", name: "Heure × jour", desc: "Quand tu écoutes le plus" },
    ],
  },
  {
    href: `${base}sound/`,
    label: "Son",
    icon: "sound",
    desc: "Genres et ambiance de ta musique",
    items: [
      { icon: "disc", name: "Genres", desc: "Ce que tu écoutes vraiment" },
      { icon: "smile", name: "Ambiance", desc: "Énergie, positivité, danceability" },
    ],
  },
  {
    href: `${base}records/`,
    label: "Records",
    icon: "records",
    desc: "Tes records et comportements d'écoute",
    items: [
      { icon: "flame", name: "Séries d'écoute", desc: "Tes streaks de jours consécutifs" },
      { icon: "repeat", name: "Titres les plus rejoués", desc: "Tes obsessions du moment" },
      { icon: "clock", name: "Sessions", desc: "Ta plus longue session d'affilée" },
    ],
  },
];

const currentPath = Astro.url.pathname;
const currentIndex = Math.max(0, links.findIndex((l) => l.href === currentPath));

function iconSvg(icon: string, cls = ""): string {
  return `<svg class="${cls}" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.8">${ICONS[icon]}</svg>`;
}

// Serialized for the client script (rebuilds the sub-list on focus change).
const clientData = links.map((l) => ({
  href: l.href,
  label: l.label,
  desc: l.desc,
  items: l.items.map((it) => ({ ...it, svg: `<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.8">${ICONS[it.icon]}</svg>` })),
}));
---

<nav class="xmb" id="xmb" data-current-index={currentIndex}>
  <div class="xmb-bg" aria-hidden="true"></div>
  <div class="xmb-ribbon" aria-hidden="true"></div>
  <div class="xmb-sweep" aria-hidden="true"></div>

  <header class="xmb-top">
    <a class="xmb-brand" href={base}>SPOTlightIFY</a>
    <time class="xmb-clock" id="xmb-clock"></time>
  </header>

  <div class="xmb-stage">
    <div class="xmb-row" id="xmb-row">
      {
        links.map((link, i) => (
          <div class="xmb-slot">
            <a
              href={link.href}
              class="xmb-tile"
              data-index={i}
              aria-current={i === currentIndex ? "page" : undefined}
              aria-label={link.label}
            >
              <span class="xmb-tile-icon" set:html={iconSvg(link.icon)} />
            </a>
            <span class="xmb-tile-label">{link.label}</span>
          </div>
        ))
      }
    </div>

    <div class="xmb-detail" id="xmb-detail">
      <ul class="xmb-sublist" id="xmb-sublist"></ul>
    </div>
  </div>

  <a class="xmb-scrollcue" href="#xmb-content" aria-label="Voir le contenu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
  </a>
</nav>
<div id="xmb-content"></div>

<script is:inline type="application/json" id="xmb-data" set:html={JSON.stringify(clientData)} />

<script>
  const nav = document.getElementById("xmb")!;
  const row = document.getElementById("xmb-row")!;
  const detail = document.getElementById("xmb-detail")!;
  const sublist = document.getElementById("xmb-sublist")!;
  const clockEl = document.getElementById("xmb-clock")!;
  const data = JSON.parse(document.getElementById("xmb-data")!.textContent!) as {
    href: string;
    label: string;
    desc: string;
    items: { name: string; desc: string; svg: string }[];
  }[];

  const slots = [...row.querySelectorAll<HTMLElement>(".xmb-slot")];
  const tiles = [...row.querySelectorAll<HTMLElement>(".xmb-tile")];

  let focusIndex = Number(nav.dataset.currentIndex ?? 0);
  let subIndex = 0;

  // --- XMB clock ---------------------------------------------------------
  function tickClock() {
    const now = new Date();
    const date = now.toLocaleDateString("fr-FR", { weekday: "short", day: "numeric", month: "short" });
    const time = now.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
    clockEl.textContent = `${date} ${time}`;
  }
  tickClock();
  setInterval(tickClock, 30_000);

  // --- Row sliding: focused tile pinned at the anchor point --------------
  function anchorX(): number {
    return Math.max(120, nav.clientWidth * 0.3);
  }

  function layout(animate = true) {
    const slotW = slots[0]?.offsetWidth ?? 104;
    const offset = anchorX() - (focusIndex + 0.5) * slotW;
    row.style.transition = animate ? "" : "none";
    row.style.transform = `translateX(${offset}px)`;
    if (!animate) void row.offsetWidth; // flush so the next change animates again
    detail.style.left = `${anchorX()}px`;
  }

  // --- Sub-list rendering ------------------------------------------------
  function renderSublist() {
    const page = data[focusIndex]!;
    sublist.innerHTML = "";
    page.items.forEach((item, i) => {
      const li = document.createElement("li");
      li.className = "xmb-sub" + (i === subIndex ? " is-selected" : "");
      li.style.animationDelay = `${80 + i * 55}ms`;
      const a = document.createElement("a");
      a.href = page.href;
      a.innerHTML = `
        <span class="xmb-sub-icon">${item.svg}</span>
        <span class="xmb-sub-text">
          <span class="xmb-sub-name">${item.name}</span>
          <span class="xmb-sub-underline"></span>
          <span class="xmb-sub-desc">${item.desc}</span>
        </span>`;
      a.addEventListener("mouseenter", () => selectSub(i));
      li.appendChild(a);
      sublist.appendChild(li);
    });
  }

  function selectSub(i: number) {
    subIndex = i;
    [...sublist.children].forEach((li, j) => li.classList.toggle("is-selected", j === subIndex));
  }

  // --- Focus handling ----------------------------------------------------
  function setFocus(i: number, { animate = true } = {}) {
    focusIndex = Math.max(0, Math.min(data.length - 1, i));
    subIndex = 0;
    tiles.forEach((t, j) => t.classList.toggle("is-focused", j === focusIndex));
    slots.forEach((s, j) => s.classList.toggle("is-focused", j === focusIndex));
    layout(animate);
    // Restart the cascade animation.
    detail.classList.remove("is-entering");
    void detail.offsetWidth;
    detail.classList.add("is-entering");
    renderSublist();
  }

  tiles.forEach((tile, i) => {
    tile.addEventListener("mouseenter", () => {
      if (i !== focusIndex) setFocus(i);
    });
  });

  // --- Keyboard: PlayStation-style ←/→/↑/↓/Enter -------------------------
  function navMostlyVisible(): boolean {
    const r = nav.getBoundingClientRect();
    return r.bottom > window.innerHeight * 0.5;
  }

  document.addEventListener("keydown", (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === "INPUT" || target.tagName === "TEXTAREA") return;
    if (!navMostlyVisible()) return;

    switch (e.key) {
      case "ArrowLeft":
        e.preventDefault();
        setFocus(focusIndex - 1);
        break;
      case "ArrowRight":
        e.preventDefault();
        setFocus(focusIndex + 1);
        break;
      case "ArrowUp":
        e.preventDefault();
        selectSub(Math.max(0, subIndex - 1));
        break;
      case "ArrowDown":
        e.preventDefault();
        selectSub(Math.min(data[focusIndex]!.items.length - 1, subIndex + 1));
        break;
      case "Enter":
        e.preventDefault();
        window.location.href = data[focusIndex]!.href;
        break;
    }
  });

  window.addEventListener("resize", () => layout(false));

  // Initial paint (no slide-in on load, then enable animation).
  setFocus(focusIndex, { animate: false });
</script>

<style is:global>
  /* is:global because the sub-list is (re)built client-side — Astro's scoped
   * styles only tag server-rendered nodes, so scoping would skip those. All
   * selectors are namespaced under .xmb / .xmb-* to stay collision-free. */
  .xmb {
    position: relative;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    isolation: isolate;
  }

  /* --- Background: deep PS3 blue + drifting glow + moving ribbon -------- */
  .xmb-bg {
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      radial-gradient(ellipse 120% 90% at 20% -10%, #2a6db5 0%, transparent 55%),
      radial-gradient(ellipse 90% 70% at 85% 105%, #123a6a 0%, transparent 60%),
      linear-gradient(160deg, #0d2c52 0%, #0a2140 45%, #071528 100%);
  }

  /* The PS3 "ribbon": a soft diagonal band drifting slowly across the screen. */
  .xmb-ribbon {
    position: absolute;
    inset: -20%;
    z-index: -2;
    background: linear-gradient(
      115deg,
      transparent 38%,
      rgba(255, 255, 255, 0.055) 46%,
      rgba(160, 210, 255, 0.11) 50%,
      rgba(255, 255, 255, 0.055) 54%,
      transparent 62%
    );
    animation: xmb-ribbon-drift 26s ease-in-out infinite alternate;
  }

  @keyframes xmb-ribbon-drift {
    from { transform: translateX(-6%) translateY(-2%) rotate(-1.5deg); }
    to { transform: translateX(6%) translateY(2%) rotate(1.5deg); }
  }

  /* Occasional light sweep passing over the whole screen. */
  .xmb-sweep {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(100deg, transparent 44%, rgba(255, 255, 255, 0.05) 50%, transparent 56%);
    background-size: 300% 100%;
    animation: xmb-sweep-move 14s ease-in-out infinite;
  }

  @keyframes xmb-sweep-move {
    0%, 55% { background-position: 120% 0; }
    85%, 100% { background-position: -60% 0; }
  }

  /* --- Top bar ----------------------------------------------------------- */
  .xmb-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
  }

  .xmb-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }

  .xmb-clock {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
    font-variant-numeric: tabular-nums;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  /* --- Stage: sliding icon row + detail column --------------------------- */
  .xmb-stage {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  .xmb-row {
    position: absolute;
    top: 22%;
    left: 0;
    display: flex;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .xmb-slot {
    position: relative;
    width: 118px;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .xmb-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.13);
    color: rgba(255, 255, 255, 0.8);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.3s ease,
      color 0.3s ease,
      box-shadow 0.45s ease;
  }

  .xmb-tile-icon {
    display: flex;
    width: 55%;
    height: 55%;
  }

  .xmb-tile:hover {
    background: rgba(255, 255, 255, 0.22);
    color: white;
  }

  .xmb-tile.is-focused {
    transform: scale(1.55);
    background: white;
    color: #0d2c52;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.6),
      0 4px 18px rgba(0, 0, 0, 0.35),
      0 0 34px 6px rgba(140, 200, 255, 0.55);
    animation: xmb-pulse 2.6s ease-in-out 0.45s infinite;
  }

  @keyframes xmb-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.6),
        0 4px 18px rgba(0, 0, 0, 0.35),
        0 0 34px 6px rgba(140, 200, 255, 0.55);
    }
    50% {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.75),
        0 4px 18px rgba(0, 0, 0, 0.35),
        0 0 48px 12px rgba(140, 200, 255, 0.75);
    }
  }

  .xmb-tile-label {
    margin-top: 1.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: white;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
    pointer-events: none;
  }

  .xmb-slot.is-focused .xmb-tile-label {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- Detail column under the focused icon ------------------------------ */
  .xmb-detail {
    position: absolute;
    top: calc(22% + 138px);
    transform: translateX(calc(-1 * 59px * 1.55 / 2));
    max-width: min(480px, 60vw);
  }

  .xmb-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .xmb-sub {
    opacity: 0;
  }

  .is-entering .xmb-sub {
    animation: xmb-sub-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes xmb-sub-in {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .xmb-sub a {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    text-decoration: none;
    padding: 0.15rem 0;
  }

  .xmb-sub-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.55);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .xmb-sub-icon svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .xmb-sub.is-selected .xmb-sub-icon {
    width: 3.1rem;
    height: 3.1rem;
    border-radius: 999px;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.08));
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3), 0 0 22px rgba(140, 200, 255, 0.35);
    color: white;
  }

  .xmb-sub.is-selected .xmb-sub-icon svg {
