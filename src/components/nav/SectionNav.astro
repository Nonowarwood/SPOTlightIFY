---
// Faithful recreation of the PS3/PS5-style XMB navigation screen referenced
// by the user (collectui.com navigation-ui-design-inspiration/21793fa2...):
// a horizontal row of icons where the focused one enlarges + glows white,
// with a detail panel below showing the current section's title/description
// and the sibling sections as a plain list.
const base = import.meta.env.BASE_URL;

const ICONS = {
  overview: `<rect x="3" y="3" width="7.5" height="9" rx="2"/><rect x="13.5" y="3" width="7.5" height="5" rx="2"/><rect x="13.5" y="10" width="7.5" height="11" rx="2"/><rect x="3" y="14" width="7.5" height="7" rx="2"/>`,
  trends: `<polyline points="3,17 9,11 13,15 21,7" fill="none"/><polyline points="15,7 21,7 21,13" fill="none"/>`,
  patterns: `<rect x="3" y="3" width="4.5" height="4.5" rx="1.2"/><rect x="9.75" y="3" width="4.5" height="4.5" rx="1.2"/><rect x="16.5" y="3" width="4.5" height="4.5" rx="1.2"/><rect x="3" y="9.75" width="4.5" height="4.5" rx="1.2"/><rect x="9.75" y="9.75" width="4.5" height="4.5" rx="1.2"/><rect x="16.5" y="9.75" width="4.5" height="4.5" rx="1.2"/><rect x="3" y="16.5" width="4.5" height="4.5" rx="1.2"/><rect x="9.75" y="16.5" width="4.5" height="4.5" rx="1.2"/><rect x="16.5" y="16.5" width="4.5" height="4.5" rx="1.2"/>`,
  sound: `<line x1="4" y1="9" x2="4" y2="15" stroke-linecap="round"/><line x1="9" y1="5" x2="9" y2="19" stroke-linecap="round"/><line x1="14" y1="2" x2="14" y2="22" stroke-linecap="round"/><line x1="19" y1="6" x2="19" y2="18" stroke-linecap="round"/>`,
  records: `<path d="M7 4h10v4.5a5 5 0 0 1-10 0V4z" fill="none"/><path d="M7 5H4.5a2.2 2.2 0 0 0 2.2 3.3" fill="none" stroke-linecap="round"/><path d="M17 5h2.5a2.2 2.2 0 0 1-2.2 3.3" fill="none" stroke-linecap="round"/><path d="M12 13.5v4" fill="none" stroke-linecap="round"/><path d="M8.5 20.5h7" fill="none" stroke-linecap="round"/>`,
};

const links = [
  { href: `${base}`, label: "Overview", icon: "overview", desc: "Vue d'ensemble de ton écoute" },
  { href: `${base}trends/`, label: "Tendances", icon: "trends", desc: "Évolution de tes écoutes dans le temps" },
  { href: `${base}patterns/`, label: "Patterns", icon: "patterns", desc: "Tes habitudes d'écoute au fil de la semaine" },
  { href: `${base}sound/`, label: "Son", icon: "sound", desc: "Genres et ambiance de ta musique" },
  { href: `${base}records/`, label: "Records", icon: "records", desc: "Tes records et comportements d'écoute" },
] as const;

const currentPath = Astro.url.pathname;
const current = links.find((l) => l.href === currentPath) ?? links[0];
const siblings = links.filter((l) => l.href !== current.href);

function iconSvg(icon: keyof typeof ICONS): string {
  return `<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.6">${ICONS[icon]}</svg>`;
}
---

<nav class="ps-nav">
  <div class="ps-nav-bg" aria-hidden="true"></div>

  <div class="ps-nav-inner">
    <a class="brand" href={base}>SPOTlightIFY</a>

    <div class="ps-icon-row">
      {
        links.map((link) => {
          const active = currentPath === link.href;
          return (
            <a href={link.href} class="ps-icon-btn" aria-current={active ? "page" : undefined} title={link.label}>
              <span class="ps-icon" set:html={iconSvg(link.icon)} />
            </a>
          );
        })
      }
    </div>

    <div class="ps-detail">
      <div class="ps-current">
        <span class="ps-current-icon" set:html={iconSvg(current.icon)} />
        <div>
          <h2 class="ps-current-title">{current.label}</h2>
          <p class="ps-current-desc">{current.desc}</p>
        </div>
      </div>

      <div class="ps-divider"></div>

      <ul class="ps-sublist">
        {
          siblings.map((link) => (
            <li>
              <a href={link.href} class="ps-sub-item">
                <span class="ps-sub-icon" set:html={iconSvg(link.icon)} />
                <span>{link.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>

<style>
  .ps-nav {
    position: relative;
    overflow: hidden;
    padding-bottom: 2.5rem;
    margin-bottom: 1rem;
  }

  .ps-nav-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(115deg, transparent 30%, color-mix(in srgb, var(--color-accent-glow) 22%, transparent) 48%, transparent 66%),
      radial-gradient(ellipse 80% 60% at 30% 0%, color-mix(in srgb, var(--color-accent-glow) 30%, transparent) 0%, transparent 65%),
      linear-gradient(180deg, #123a63 0%, #0a2340 55%, var(--color-page) 100%);
  }

  .ps-nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
  }

  .brand {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: -0.01em;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .ps-icon-row {
    display: flex;
    gap: 2.5rem;
    margin-bottom: 1.75rem;
  }

  .ps-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.75);
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .ps-icon-btn .ps-icon {
    width: 55%;
    height: 55%;
  }

  .ps-icon-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .ps-icon-btn[aria-current="page"] {
    width: 4rem;
    height: 4rem;
    background: white;
    color: #0a2340;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.5), 0 0 30px 4px color-mix(in srgb, var(--color-accent-glow) 70%, transparent);
  }

  .ps-detail {
    max-width: 420px;
  }

  .ps-current {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .ps-current-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent-glow) 35%, transparent);
    color: white;
  }

  .ps-current-icon svg {
    width: 50%;
    height: 50%;
  }

  .ps-current-title {
    font-size: 1.5rem;
    color: white;
    margin: 0;
  }

  .ps-current-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0.2rem 0 0;
  }

  .ps-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
    margin: 1.1rem 0 0.85rem 4rem;
  }

  .ps-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .ps-sub-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-left: 4rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    transition: color 0.2s ease;
  }

  .ps-sub-item:hover {
    color: white;
  }

  .ps-sub-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .ps-icon-row {
      gap: 1.25rem;
    }
    .ps-divider,
    .ps-sub-item {
      margin-left: 0;
      padding-left: 0;
    }
  }
</style>
