---
---

<div id="gate-overlay" class="gate-overlay">
  <div class="gate-card">
    <p class="gate-eyebrow">spotlightify // access control</p>
    <h1 class="gate-title">AUTHENTIFICATION REQUISE</h1>
    <p class="gate-copy">$ entrer le mot de passe pour accéder au tableau de bord</p>
    <form id="gate-form" autocomplete="off">
      <div class="gate-input-row">
        <span class="gate-prompt">&gt;</span>
        <input
          id="gate-input"
          type="password"
          name="passphrase"
          placeholder="mot de passe"
          autofocus
        />
      </div>
      <button type="submit">[ entrer ]</button>
    </form>
    <p id="gate-error" class="gate-error" hidden>ERREUR: mot de passe incorrect</p>
    <label class="gate-remember">
      <input id="gate-remember" type="checkbox" checked />
      se souvenir de moi sur cet appareil
    </label>
  </div>
</div>

<script>
  import { sha256Hex, markUnlocked, isUnlocked, unlockWithoutPersisting } from "../../lib/gate.ts";

  const overlay = document.getElementById("gate-overlay") as HTMLDivElement;
  const form = document.getElementById("gate-form") as HTMLFormElement;
  const input = document.getElementById("gate-input") as HTMLInputElement;
  const error = document.getElementById("gate-error") as HTMLParagraphElement;
  const remember = document.getElementById("gate-remember") as HTMLInputElement;

  const expectedHash = import.meta.env.PUBLIC_PASSPHRASE_HASH as string | undefined;

  function hide() {
    overlay.style.display = "none";
    document.body.style.overflow = "";
  }

  if (isUnlocked()) {
    hide();
  } else if (!expectedHash) {
    // No passphrase configured (e.g. local dev without the secret set) — don't
    // lock the developer out of their own site. markUnlocked() (not just hide())
    // matters here: page scripts' onUnlock() checks isUnlocked() synchronously,
    // and this script block runs before theirs, so the state must be persisted
    // for them to see it — a live-only event dispatched here would already be
    // gone by the time they start listening.
    markUnlocked();
    hide();
  } else {
    document.body.style.overflow = "hidden";
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!expectedHash) return;
    const hash = await sha256Hex(input.value);
    if (hash === expectedHash) {
      if (remember.checked) markUnlocked();
      else unlockWithoutPersisting();
      hide();
    } else {
      error.hidden = false;
      input.value = "";
      input.focus();
    }
  });
</script>

<style>
  .gate-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-page);
  }

  .gate-card {
    max-width: 420px;
    width: 90%;
    border: 1px solid var(--color-border);
    padding: 2rem;
    background: var(--color-card);
  }

  .gate-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    margin: 0 0 1rem;
  }

  .gate-title {
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.75rem;
  }

  .gate-copy {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0 0 1.5rem;
  }

  .gate-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-page);
    padding: 0.7rem 0.9rem;
    margin-bottom: 0.75rem;
  }

  .gate-input-row:focus-within {
    border-color: var(--color-accent);
  }

  .gate-prompt {
    color: var(--color-accent);
  }

  #gate-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  #gate-input:focus {
    outline: none;
  }

  #gate-form button {
    width: 100%;
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.65rem 1.1rem;
    font-family: var(--font-body);
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  #gate-form button:hover {
    background: var(--color-accent);
    color: var(--color-page);
  }

  .gate-error {
    color: var(--color-cat-8);
    font-size: 0.8rem;
    margin-top: 0.75rem;
  }

  .gate-remember {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: var(--color-text-faint);
  }
</style>
