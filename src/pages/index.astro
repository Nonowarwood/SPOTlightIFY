---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Overview">
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <p class="section-title">Temps d'écoute total</p>
    <p id="hero-number" class="hero-number tabular">—</p>
    <p id="hero-sub" class="hero-sub"></p>
  </section>

  <section class="stack">
    <div class="grid-2">
      <div class="card">
        <p class="section-title">Titres uniques</p>
        <p id="stat-tracks" class="stat-value tabular">—</p>
      </div>
      <div class="card">
        <p class="section-title">Artistes uniques</p>
        <p id="stat-artists" class="stat-value tabular">—</p>
      </div>
    </div>

    <div class="card">
      <p class="section-title">Top artistes (30 derniers jours)</p>
      <div id="top-artists"></div>
    </div>

    <div class="grid-2">
      <div class="card">
        <p class="section-title">Top titres (30 derniers jours)</p>
        <div id="top-tracks"></div>
      </div>
      <div class="card">
        <p class="section-title">Top albums (30 derniers jours)</p>
        <div id="top-albums"></div>
      </div>
    </div>

    <div id="approx-history-section" hidden>
      <div class="approx-header">
        <p class="section-title">Aperçu longue durée</p>
        <p class="approx-note">
          Classement approximatif calculé par Spotify (pas nos stats précises minute par minute) —
          en attendant l'import de ton historique complet.
        </p>
      </div>
      <div class="grid-2">
        <div class="card">
          <p class="section-title">Top artistes · 6 derniers mois</p>
          <div id="approx-artists-medium"></div>
        </div>
        <div class="card">
          <p class="section-title">Top artistes · longue durée</p>
          <div id="approx-artists-long"></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 3rem 0 2rem;
    isolation: isolate;
  }

  .hero-glow {
    position: absolute;
    top: -140px;
    left: -80px;
    width: 420px;
    height: 420px;
    background: var(--gradient-hero);
    filter: blur(90px);
    opacity: 0.35;
    z-index: -1;
    border-radius: 50%;
  }

  .hero-number {
    font-size: clamp(2.75rem, 9vw, 4.5rem);
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1;
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .stat-value {
    font-size: 1.8rem;
    font-family: var(--font-display);
  }

  .approx-header {
    margin-bottom: 1rem;
  }

  .approx-note {
    color: var(--color-text-faint);
    font-size: 0.8rem;
    margin: 0.25rem 0 0;
  }
</style>

<script>
  import { onUnlock } from "../lib/gate.ts";
  import { formatDuration, formatNumber, formatPercent } from "../lib/theme.ts";
  import { animateBigNumber } from "../components/charts/bigNumber.ts";
  import { renderTopList } from "../components/charts/topList.ts";
  import type { ApproxHistoryData, OverviewData } from "../lib/data-types.ts";

  onUnlock(async () => {
    const res = await fetch(`${import.meta.env.BASE_URL}data/overview.json`);
    if (!res.ok) return;
    const data = (await res.json()) as OverviewData;

    const heroEl = document.getElementById("hero-number")!;
    animateBigNumber(heroEl, data.totalMsAllTime, (v) => formatDuration(v));

    const subEl = document.getElementById("hero-sub")!;
    const delta = data.deltas.last30dVsPrevious30dPct;
    if (delta !== null) {
      const sign = delta >= 0 ? "+" : "";
      subEl.textContent = `${sign}${formatPercent(delta)} vs les 30 jours précédents`;
    }

    document.getElementById("stat-tracks")!.textContent = formatNumber(data.uniqueTracks);
    document.getElementById("stat-artists")!.textContent = formatNumber(data.uniqueArtists);

    const w = data.windows.last30d;
    renderTopList(
      document.getElementById("top-artists")!,
      w.topArtists.map((a) => ({ label: a.name, value: a.minutes, imageUrl: a.imageUrl })),
      (n) => `${formatNumber(n)} min`,
      "circle",
    );
    renderTopList(
      document.getElementById("top-tracks")!,
      w.topTracks.map((t) => ({ label: t.name, sublabel: t.sublabel, value: t.minutes, imageUrl: t.imageUrl })),
      (n) => `${formatNumber(n)} min`,
    );
    renderTopList(
      document.getElementById("top-albums")!,
      w.topAlbums.map((a) => ({ label: a.name, sublabel: a.sublabel, value: a.minutes, imageUrl: a.imageUrl })),
      (n) => `${formatNumber(n)} min`,
    );

    const approxRes = await fetch(`${import.meta.env.BASE_URL}data/approx-history.json`);
    if (approxRes.ok) {
      const approx = (await approxRes.json()) as ApproxHistoryData;
      document.getElementById("approx-history-section")!.hidden = false;
      renderTopList(
        document.getElementById("approx-artists-medium")!,
        approx.mediumTerm.topArtists.slice(0, 8).map((a) => ({ label: a.name, imageUrl: a.imageUrl, value: a.minutes })),
        () => "",
        "circle",
      );
      renderTopList(
        document.getElementById("approx-artists-long")!,
        approx.longTerm.topArtists.slice(0, 8).map((a) => ({ label: a.name, imageUrl: a.imageUrl, value: a.minutes })),
        () => "",
        "circle",
      );
    }
  });
</script>
