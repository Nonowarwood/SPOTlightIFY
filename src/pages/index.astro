---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Overview">
  <section class="hero">
    <p class="section-title">Temps d'écoute total</p>
    <p id="hero-number" class="hero-number tabular">—</p>
    <p id="hero-sub" class="hero-sub"></p>
    <p id="coverage-note" class="coverage-note" hidden></p>
  </section>

  <div class="dash-grid">
    <div class="dash-main stack">
      <div class="card">
        <div class="ov-card-head">
          <p class="section-title">Activité</p>
          <span id="chart-period" class="ov-period-label"></span>
        </div>
        <div id="daily-chart"></div>
      </div>

      <div class="card">
        <p id="top-tracks-label" class="section-title">Top titres</p>
        <div id="top-tracks-hero" class="ov-track-heroes"></div>
        <div id="top-tracks"></div>
      </div>

      <div class="card">
        <p id="top-albums-label" class="section-title">Top albums</p>
        <div id="top-albums" class="ov-album-grid"></div>
      </div>
    </div>

    <aside class="dash-rail stack">
      <div class="ov-mini-row">
        <div class="card ov-mini">
          <p class="section-title">Titres</p>
          <p id="stat-tracks" class="stat-value tabular">—</p>
        </div>
        <div class="card ov-mini">
          <p class="section-title">Artistes</p>
          <p id="stat-artists" class="stat-value tabular">—</p>
        </div>
      </div>

      <div class="card">
        <p id="top-artists-label" class="section-title">Top artistes</p>
        <ul id="artist-rail" class="ov-artist-rail"></ul>
      </div>

      <div class="ov-gradient-card">
        <p id="gc-number" class="ov-gc-number tabular">—</p>
        <p class="ov-gc-label">écoutes enregistrées</p>
      </div>
    </aside>
  </div>

  <section id="approx-history-section" class="stack approx-section" hidden>
    <div class="approx-header">
      <div>
        <p class="section-title">Aperçu longue durée</p>
        <p class="approx-note">
          Classement approximatif calculé par Spotify (pas nos stats précises minute par minute) —
          en attendant l'import de ton historique complet.
        </p>
      </div>
      <div class="period-toggle" role="group" aria-label="Période">
        <button type="button" class="period-btn is-active" data-period="mediumTerm">6 mois</button>
        <button type="button" class="period-btn" data-period="longTerm">Longue durée</button>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <p class="section-title">Top artistes</p>
        <div id="approx-artists"></div>
      </div>
      <div class="card">
        <p class="section-title">Top titres</p>
        <div id="approx-tracks"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* is:global (namespaced .ov-*) because most of these nodes are built
   * client-side — Astro's scoped styles would skip them. */

  .hero {
    padding: 2.5rem 0 1.75rem;
  }

  .hero-number {
    font-size: clamp(2.9rem, 9vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
    font-family: var(--font-display);
    margin: 0;
  }

  .hero-sub {
    font-size: 0.92rem;
    margin-top: 0.6rem;
    color: var(--color-text-muted);
  }

  .hero-sub.is-up {
    color: var(--color-cat-5);
  }

  .hero-sub.is-down {
    color: var(--color-cat-8);
  }

  .coverage-note {
    color: var(--color-text-faint);
    font-size: 0.8rem;
    margin-top: 0.7rem;
    max-width: 46ch;
    line-height: 1.5;
  }

  /* --- Dashboard grid ----------------------------------------------------- */
  .dash-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .dash-grid {
      grid-template-columns: minmax(0, 1fr) 340px;
    }
  }

  .ov-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .ov-period-label {
    font-size: 0.75rem;
    color: var(--color-text-faint);
  }

  .ov-mini-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .ov-mini {
    padding: 1.1rem 1.25rem;
  }

  .stat-value {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-family: var(--font-display);
    margin: 0;
  }

  /* --- Top-3 track hero cards --------------------------------------------- */
  .ov-track-heroes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(168px, 1fr));
    gap: 0.9rem;
    margin-bottom: 1.1rem;
  }

  .ov-track-hero {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: var(--color-card-hover);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 0.8rem 0.95rem;
    min-width: 0;
  }

  .ov-track-hero-art {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
    background: rgba(255, 255, 255, 0.06);
  }

  .ov-track-hero-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ov-track-hero-name {
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-track-hero-artist {
    font-size: 0.76rem;
    color: var(--color-text-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-track-hero-min {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .ov-track-hero-min::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--color-accent);
  }

  /* --- Album cover grid ---------------------------------------------------- */
  .ov-album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.1rem;
  }

  .ov-album {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
  }

  .ov-album-art {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 14px;
    object-fit: cover;
    display: block;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ov-album:hover .ov-album-art {
    transform: scale(1.04);
  }

  .ov-album-art--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-text-faint);
  }

  .ov-album-name {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-album-sub {
    font-size: 0.72rem;
    color: var(--color-text-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* --- Artist rail ---------------------------------------------------------- */
  .ov-artist-rail {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .ov-artist {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .ov-artist:last-child {
    border-bottom: none;
  }

  .ov-artist-pic {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
    background: rgba(255, 255, 255, 0.06);
  }

  .ov-artist-pic--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-text-faint);
  }

  .ov-artist-name {
    flex: 1;
    min-width: 0;
    font-size: 0.88rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-artist-badge {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
    color: #a8e0ff;
  }

  .ov-artist-badge.is-gold {
    background: color-mix(in srgb, var(--color-accent-2) 16%, transparent);
    color: #ffd98a;
  }

  /* --- Gradient highlight card ---------------------------------------------- */
  .ov-gradient-card {
    background: var(--gradient-hero);
    border-radius: var(--radius-card);
    padding: 1.75rem 1.5rem;
    text-align: center;
    color: #0c2038;
  }

  .ov-gc-number {
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
  }

  .ov-gc-label {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0.45rem 0 0;
    opacity: 0.75;
  }

  /* --- Approx section (unchanged behavior) ----------------------------------- */
  .approx-section {
    margin-top: 1.25rem;
  }

  .approx-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .approx-note {
    color: var(--color-text-faint);
    font-size: 0.8rem;
    margin: 0.25rem 0 0;
    max-width: 40ch;
    line-height: 1.5;
  }

  .period-toggle {
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 2px;
    flex-shrink: 0;
  }

  .period-btn {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--font-body);
    padding: 0.4rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .period-btn:hover {
    color: var(--color-text);
  }

  .period-btn.is-active {
    background: rgba(255, 255, 255, 0.22);
    color: var(--color-text);
    font-weight: 600;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }
</style>

<script>
  import { onUnlock } from "../lib/gate.ts";
  import { formatDuration, formatNumber, formatPercent } from "../lib/theme.ts";
  import { animateBigNumber } from "../components/charts/bigNumber.ts";
  import { renderTopList } from "../components/charts/topList.ts";
  import { renderTrendLine } from "../components/charts/trendLine.ts";
  import type { ApproxHistoryData, MetaData, OverviewData, RankedItem, TrendsData } from "../lib/data-types.ts";

  function el(id: string): HTMLElement {
    return document.getElementById(id)!;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function artHtml(item: RankedItem, cls: string, fallbackCls: string): string {
    if (item.imageUrl) return `<img class="${cls}" src="${item.imageUrl}" alt="" loading="lazy" />`;
    return `<span class="${cls} ${fallbackCls}">${escapeHtml(item.name.charAt(0).toUpperCase())}</span>`;
  }

  onUnlock(async () => {
    const res = await fetch(`${import.meta.env.BASE_URL}data/overview.json`);
    if (!res.ok) return;
    const data = (await res.json()) as OverviewData;

    animateBigNumber(el("hero-number"), data.totalMsAllTime, (v) => formatDuration(v));

    const delta = data.deltas.last30dVsPrevious30dPct;
    if (delta !== null) {
      const subEl = el("hero-sub");
      const sign = delta >= 0 ? "+" : "";
      subEl.textContent = `${sign}${formatPercent(delta)} vs les 30 jours précédents`;
      subEl.classList.add(delta >= 0 ? "is-up" : "is-down");
    }

    el("stat-tracks").textContent = formatNumber(data.uniqueTracks);
    el("stat-artists").textContent = formatNumber(data.uniqueArtists);

    // "30 derniers jours" is only honest once the tracker has actually been
    // running that long — otherwise it silently means "since tracking started"
    // and looks like missing/wrong data next to Spotify's own lifetime stats.
    const coverageDays = data.firstPlayDate ? (Date.now() - Date.parse(data.firstPlayDate)) / 86_400_000 : null;

    const windowSuffix =
      coverageDays === null
        ? ""
        : coverageDays >= 30
          ? " (30 derniers jours)"
          : coverageDays >= 1
            ? ` (depuis le début du suivi — ${Math.floor(coverageDays)} j)`
            : ` (depuis le début du suivi — ${Math.max(1, Math.round(coverageDays * 24))} h)`;

    el("top-artists-label").textContent = `Top artistes${windowSuffix}`;
    el("top-tracks-label").textContent = `Top titres${windowSuffix}`;
    el("top-albums-label").textContent = `Top albums${windowSuffix}`;
    el("chart-period").textContent =
      coverageDays !== null && coverageDays >= 30 ? "30 derniers jours" : "depuis le début du suivi";

    if (coverageDays !== null && coverageDays < 30) {
      const note = el("coverage-note");
      note.hidden = false;
      note.textContent =
        'Ce total ne reflète que le suivi précis démarré récemment — pas ton historique Spotify complet. ' +
        'Regarde "Aperçu longue durée" plus bas pour un classement basé sur tout ton historique, ' +
        "et importe ton export Spotify pour des stats précises sur le long terme.";
    }

    const w = data.windows.last30d;

    // Top-3 tracks as hero cards with big artwork, the rest as a list.
    el("top-tracks-hero").innerHTML = w.topTracks
      .slice(0, 3)
      .map(
        (t) => `
        <div class="ov-track-hero">
          ${artHtml(t, "ov-track-hero-art", "ov-album-art--fallback")}
          <div class="ov-track-hero-body">
            <span class="ov-track-hero-name">${escapeHtml(t.name)}</span>
            ${t.sublabel ? `<span class="ov-track-hero-artist">${escapeHtml(t.sublabel)}</span>` : ""}
            <span class="ov-track-hero-min tabular">${formatNumber(t.minutes)} min</span>
          </div>
        </div>`,
      )
      .join("");

    renderTopList(
      el("top-tracks"),
      w.topTracks.slice(3, 12).map((t) => ({ label: t.name, sublabel: t.sublabel, value: t.minutes, imageUrl: t.imageUrl })),
      (n) => `${formatNumber(n)} min`,
    );

    // Albums as a big cover grid.
    el("top-albums").innerHTML = w.topAlbums
      .slice(0, 8)
      .map(
        (a) => `
        <div class="ov-album">
          ${artHtml(a, "ov-album-art", "ov-album-art--fallback")}
          <span class="ov-album-name">${escapeHtml(a.name)}</span>
          <span class="ov-album-sub">${a.sublabel ? escapeHtml(a.sublabel) + " · " : ""}${formatNumber(a.minutes)} min</span>
        </div>`,
      )
      .join("");

    // Artist rail with photo + minutes badge (gold badge for #1, ref-style).
    el("artist-rail").innerHTML = w.topArtists
      .slice(0, 8)
      .map(
        (a, i) => `
        <li class="ov-artist">
          ${artHtml(a, "ov-artist-pic", "ov-artist-pic--fallback")}
          <span class="ov-artist-name">${escapeHtml(a.name)}</span>
          <span class="ov-artist-badge${i === 0 ? " is-gold" : ""}">${formatNumber(a.minutes)} min</span>
        </li>`,
      )
      .join("");

    // Daily-minutes area chart, dashboard-style.
    const trendsRes = await fetch(`${import.meta.env.BASE_URL}data/trends.json`);
    if (trendsRes.ok) {
      const trends = (await trendsRes.json()) as TrendsData;
      const daily = trends.daily.slice(-30);
      renderTrendLine(
        el("daily-chart"),
        [{ name: "Minutes", points: daily.map((p) => ({ date: new Date(p.date), value: p.minutes })) }],
        (n) => `${formatNumber(n)} min`,
        { height: 230, area: true },
      );
    }

    // Gradient highlight card: total recorded plays.
    const metaRes = await fetch(`${import.meta.env.BASE_URL}data/meta.json`);
    if (metaRes.ok) {
      const meta = (await metaRes.json()) as MetaData;
      animateBigNumber(el("gc-number"), meta.recordCount, (v) => formatNumber(v));
    }

    const approxRes = await fetch(`${import.meta.env.BASE_URL}data/approx-history.json`);
    if (approxRes.ok) {
      const approx = (await approxRes.json()) as ApproxHistoryData;
      el("approx-history-section").hidden = false;

      const asItems = (items: (typeof approx.mediumTerm.topArtists)) =>
        items.slice(0, 20).map((a) => ({ label: a.name, sublabel: a.sublabel, imageUrl: a.imageUrl, value: a.minutes }));

      function renderPeriod(period: "mediumTerm" | "longTerm") {
        const bucket = approx[period];
        renderTopList(el("approx-artists"), asItems(bucket.topArtists), () => "", "circle");
        renderTopList(el("approx-tracks"), asItems(bucket.topTracks), () => "");
      }

      renderPeriod("mediumTerm");

      document.querySelectorAll<HTMLButtonElement>(".period-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".period-btn").forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
          renderPeriod(btn.dataset.period as "mediumTerm" | "longTerm");
        });
      });
    }
  });
</script>
