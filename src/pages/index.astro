---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Overview">
  <section class="hero">
    <p class="section-title">Temps d'écoute total</p>
    <p id="hero-number" class="hero-number tabular">—</p>
    <p id="hero-sub" class="hero-sub"></p>
    <p id="coverage-note" class="coverage-note" hidden></p>
  </section>

  <section class="stack">
    <div class="grid-2">
      <div class="card">
        <p class="section-title">Titres uniques</p>
        <p id="stat-tracks" class="stat-value tabular">—</p>
      </div>
      <div class="card">
        <p class="section-title">Artistes uniques</p>
        <p id="stat-artists" class="stat-value tabular">—</p>
      </div>
    </div>

    <div class="card">
      <p id="top-artists-label" class="section-title">Top artistes</p>
      <div id="top-artists"></div>
    </div>

    <div class="grid-2">
      <div class="card">
        <p id="top-tracks-label" class="section-title">Top titres</p>
        <div id="top-tracks"></div>
      </div>
      <div class="card">
        <p id="top-albums-label" class="section-title">Top albums</p>
        <div id="top-albums"></div>
      </div>
    </div>

    <div id="approx-history-section" class="stack" hidden>
      <div class="approx-header">
        <div>
          <p class="section-title">Aperçu longue durée</p>
          <p class="approx-note">
            Classement approximatif calculé par Spotify (pas nos stats précises minute par minute) —
            en attendant l'import de ton historique complet.
          </p>
        </div>
        <div class="period-toggle" role="group" aria-label="Période">
          <button type="button" class="period-btn is-active" data-period="mediumTerm">6 mois</button>
          <button type="button" class="period-btn" data-period="longTerm">Longue durée</button>
        </div>
      </div>

      <div class="grid-2">
        <div class="card">
          <p class="section-title">Top artistes</p>
          <div id="approx-artists"></div>
        </div>
        <div class="card">
          <p class="section-title">Top titres</p>
          <div id="approx-tracks"></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Apple Health-style hero: quiet label, huge solid number, footnote. */
  .hero {
    padding: 2.75rem 0 2rem;
  }

  .hero-number {
    font-size: clamp(2.9rem, 9vw, 4.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin-top: 0.6rem;
  }

  .coverage-note {
    color: var(--color-text-faint);
    font-size: 0.8rem;
    margin-top: 0.7rem;
    max-width: 46ch;
    line-height: 1.5;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-family: var(--font-display);
  }

  .approx-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .approx-note {
    color: var(--color-text-faint);
    font-size: 0.8rem;
    margin: 0.25rem 0 0;
    max-width: 40ch;
    line-height: 1.5;
  }

  /* iOS segmented control. */
  .period-toggle {
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 2px;
    flex-shrink: 0;
  }

  .period-btn {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--font-body);
    padding: 0.4rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .period-btn:hover {
    color: var(--color-text);
  }

  .period-btn.is-active {
    background: rgba(255, 255, 255, 0.22);
    color: var(--color-text);
    font-weight: 600;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }
</style>

<script>
  import { onUnlock } from "../lib/gate.ts";
  import { formatDuration, formatNumber, formatPercent } from "../lib/theme.ts";
  import { animateBigNumber } from "../components/charts/bigNumber.ts";
  import { renderTopList } from "../components/charts/topList.ts";
  import type { ApproxHistoryData, OverviewData } from "../lib/data-types.ts";

  onUnlock(async () => {
    const res = await fetch(`${import.meta.env.BASE_URL}data/overview.json`);
    if (!res.ok) return;
    const data = (await res.json()) as OverviewData;

    const heroEl = document.getElementById("hero-number")!;
    animateBigNumber(heroEl, data.totalMsAllTime, (v) => formatDuration(v));

    const subEl = document.getElementById("hero-sub")!;
    const delta = data.deltas.last30dVsPrevious30dPct;
    if (delta !== null) {
      const sign = delta >= 0 ? "+" : "";
      subEl.textContent = `${sign}${formatPercent(delta)} vs les 30 jours précédents`;
    }

    document.getElementById("stat-tracks")!.textContent = formatNumber(data.uniqueTracks);
    document.getElementById("stat-artists")!.textContent = formatNumber(data.uniqueArtists);

    // "30 derniers jours" is only honest once the tracker has actually been
    // running that long — otherwise it silently means "since tracking started"
    // and looks like missing/wrong data next to Spotify's own lifetime stats.
    const coverageDays = data.firstPlayDate ? (Date.now() - Date.parse(data.firstPlayDate)) / 86_400_000 : null;

    const windowSuffix =
      coverageDays === null
        ? ""
        : coverageDays >= 30
          ? " (30 derniers jours)"
          : coverageDays >= 1
            ? ` (depuis le début du suivi — ${Math.floor(coverageDays)} j)`
            : ` (depuis le début du suivi — ${Math.max(1, Math.round(coverageDays * 24))} h)`;

    document.getElementById("top-artists-label")!.textContent = `Top artistes${windowSuffix}`;
    document.getElementById("top-tracks-label")!.textContent = `Top titres${windowSuffix}`;
    document.getElementById("top-albums-label")!.textContent = `Top albums${windowSuffix}`;

    if (coverageDays !== null && coverageDays < 30) {
      const note = document.getElementById("coverage-note")!;
      note.hidden = false;
      note.textContent =
        'Ce total ne reflète que le suivi précis démarré récemment — pas ton historique Spotify complet. ' +
        'Regarde "Aperçu longue durée" plus bas pour un classement basé sur tout ton historique, ' +
        "et importe ton export Spotify pour des stats précises sur le long terme.";
    }

    const w = data.windows.last30d;
    renderTopList(
      document.getElementById("top-artists")!,
      w.topArtists.map((a) => ({ label: a.name, value: a.minutes, imageUrl: a.imageUrl })),
      (n) => `${formatNumber(n)} min`,
      "circle",
    );
    renderTopList(
      document.getElementById("top-tracks")!,
      w.topTracks.map((t) => ({ label: t.name, sublabel: t.sublabel, value: t.minutes, imageUrl: t.imageUrl })),
      (n) => `${formatNumber(n)} min`,
    );
    renderTopList(
      document.getElementById("top-albums")!,
      w.topAlbums.map((a) => ({ label: a.name, sublabel: a.sublabel, value: a.minutes, imageUrl: a.imageUrl })),
      (n) => `${formatNumber(n)} min`,
    );

    const approxRes = await fetch(`${import.meta.env.BASE_URL}data/approx-history.json`);
    if (approxRes.ok) {
      const approx = (await approxRes.json()) as ApproxHistoryData;
      document.getElementById("approx-history-section")!.hidden = false;

      const asItems = (items: (typeof approx.mediumTerm.topArtists)) =>
        items.slice(0, 20).map((a) => ({ label: a.name, sublabel: a.sublabel, imageUrl: a.imageUrl, value: a.minutes }));

      function renderPeriod(period: "mediumTerm" | "longTerm") {
        const bucket = approx[period];
        renderTopList(document.getElementById("approx-artists")!, asItems(bucket.topArtists), () => "", "circle");
        renderTopList(document.getElementById("approx-tracks")!, asItems(bucket.topTracks), () => "");
      }

      renderPeriod("mediumTerm");

      document.querySelectorAll<HTMLButtonElement>(".period-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".period-btn").forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
          renderPeriod(btn.dataset.period as "mediumTerm" | "longTerm");
        });
      });
    }
  });
</script>
