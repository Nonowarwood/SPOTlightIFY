{
  "name": "spotlightify",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Personal, ultra-precise Spotify listening dashboard. Public static site — only ever ships pre-aggregated stats, never raw per-play data.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "aggregate": "tsx scripts/aggregate/index.ts",
    "fixture:generate": "tsx scripts/aggregate/fixture/generate-fixture.ts",
    "fixture:build": "npm run fixture:generate && npm run aggregate -- --input .fixture-data --output public/data && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/sora": "^5.3.0",
    "astro": "^7.1.3",
    "d3-array": "^3.2.4",
    "d3-ease": "^3.0.1",
    "d3-format": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/d3-array": "^3.2.2",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-format": "^3.0.4",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/d3-transition": "^3.0.9",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1"
  }
}
